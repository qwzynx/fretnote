// Dark, warm theme translated in spirit from the old Tailwind/oklch tokens
// (primary is the amber accent oklch(0.78 0.16 68)).
export global Theme {
    out property <color> background: #17150f;
    out property <color> surface: #201d16;
    out property <color> surface-alt: #262218;
    out property <color> foreground: #f3f0e8;
    out property <color> muted: #b0a992;
    out property <color> muted-dim: #6f6a5d;
    out property <color> border: #33302a;
    out property <color> primary: #e39b45;
    out property <color> primary-dim: #a9803f;
    out property <color> primary-foreground: #241f14;

    out property <length> radius: 10px;
    out property <length> radius-sm: 6px;

    out property <length> font-sm: 13px;
    out property <length> font-md: 15px;
    out property <length> font-lg: 20px;
    out property <string> mono-family: "monospace";
}
